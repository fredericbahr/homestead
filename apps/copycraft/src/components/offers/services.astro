---
import Card from "../ui/card.astro";
import Button from "../ui/button.astro";

interface Service {
  icon: string;
  title: string;
  examples: string;
  hook: string;
  description: string;
}

const services: Service[] = [
  {
    icon: "globe-simple",
    title: "Website & Onepager",
    examples: "(Startseite, Über-mich-Seite, Angebotsseite, etc.)",
    hook: "Dein Internetauftritt ist deine Online-Visitenkarte.",
    description:
      "Umso wichtiger, dass die Texte deine Persönlichkeit widerspiegeln. Das Ziel: Besucher zu Fans werden lassen.",
  },
  {
    icon: "share-network",
    title: "Werbeanzeigen & Social Media",
    examples: "(Captions und Ads auf Instagram, Facebook und Google)",
    hook: "Dafür unterbrechen die Menschen ihr Handyscrollen.",
    description:
      "Texte, an denen die Leser interessiert hängenbleiben und die auf dich und dein Angebot aufmerksam machen, ohne sich nach lautstarker Werbung anzufühlen.",
  },
  {
    icon: "file-text",
    title: "Landingpages & Salespages",
    examples: "(0 €-Produkte, Online-Programme, Coaching, etc.)",
    hook: "Der rote Faden für dein Angebot.",
    description:
      "Kein Marktgeschrei und kein langes Bli-Bla-Blub, aber dennoch strategisch aufgebaut, um Besucher vom nächsten Schritt zu überzeugen und deine Erfolgsrate zu erhöhen.",
  },
  {
    icon: "envelope-simple",
    title: "Newsletter & E-Mail-Marketing",
    examples: "(Willkommenssequenzen, Story-Mails, Sales-Mails, etc.)",
    hook: "Vertrauensaufbau at its best. ",
    description:
      "Deine Wunschkunden lernen dich über regelmäßige E-Mail-Sequenzen kennen und lieben. Ehe du dich versiehst, werden aus deinen Kunden eine Community.",
  },
];
---

<section class="bg-background flex flex-col gap-8 md:gap-12 items-center justify-center px-6 py-24 text-center">
  <div class="space-y-4 text-center">
    <span class="font-hand text-primary text-xl md:text-2xl">Hilfe ist unterwegs: Copywriting it is!</span>
    <h2 class="font-heading text-foreground text-3xl font-bold md:text-5xl mt-2">Meine Angebote</h2>
  </div>

  <p class="text-center text-lg md:text-xl">
    Die harte Realität ist doch, dass die meisten Menschen mittlerweile einen „Bitte keine Werbung“-Sticker an ihrem
    Briefkasten kleben haben. Umso wichtiger ist es heutzutage für <strong>dein Business, digital vertreten</strong> zu sein
    – und dabei unterstütze ich dich gern mit Conversion Copywriting!
  </p>

  <div class="flex gap-8 justify-center items-stretch flex-wrap">
    {
      services.map((service) => (
        <Card>
          <div class="text-start">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6 transition-transform group-hover:scale-110 bg-primary/30">
              <i class={`ph ph-${service.icon} text-3xl text-accent`} />
            </div>

            <p class="text-2xl font-bold leading-none tracking-[-0.03em]">{service.title}</p>
            <p class="mt-4 text-sm">{service.examples}</p>
            <p class="text-accent font-semibold mt-4">{service.hook}</p>
            <p class="mt-4 leading-[1.7]">{service.description}</p>
          </div>
        </Card>
      ))
    }
  </div>

  <div class="flex flex-col gap-4">
    <p class="text-muted-foreground max-w-3xl text-md leading-relaxed md:text-xl">
      Na, hast du gefunden, was du suchst? <br />
      Dann bleibt mir nichts anderes zu sagen als: „<span class="font-bold">Ran an den Text</span>“!
    </p>

    <div class="flex justify-center">
      <Button href="/kontakt" title="Kennenlern-Call buchen" class="px-8 py-2 text-md md:text-lg">
        Kennenlern-Call buchen
      </Button>
    </div>

    <p class="italic text-sm mt-2 text-center md:text-start">
      Mit nur einem Klick auf den leuchtend-orangenen Button gelangst du zur Buchung unseres Kennenlern-Calls
    </p>
  </div>
</section>
