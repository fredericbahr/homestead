---
import { Image } from "astro:assets";
import Button from "../ui/button.astro";
import HeroImage from "@assets/offers.png";
---

<section
  class="relative flex min-h-[90vh] flex-col items-center overflow-hidden px-6 py-12 md:flex-row md:px-12 lg:px-24"
  id="home"
>
  <div class="relative mt-12 w-full md:mt-0 md:w-1/2">
    <div class="relative z-10">
      <Image alt="Hero" class="h-auto w-[95%] mx-auto rounded-[3rem] md:w-[65%]" src={HeroImage} />
    </div>
  </div>

  <div class="relative z-10 w-full space-y-8 md:w-1/2">
    <div>
      <span class="font-hand text-primary mb-4 inline-block text-xl md:text-2xl">
        Texter-Angebote für Dienstleister
      </span>
      <h1 class="font-heading text-foreground mb-6 text-4xl leading-[1.1] font-bold md:text-5xl">
        Texte gut, alles gut!
      </h1>
      <p class="text-muted-foreground max-w-xl text-md leading-relaxed md:text-xl">
        Werbung sollte sich nicht nach Werbung anfühlen. Hol‘ dir für deine Botschaften die Kombo aus Herz,
        Schreibfreude und psychologischem Know-how, um wirklich bei deinen Kunden anzukommen.
      </p>

      <a href="/kontakt">
        <Button class="mt-8 px-8 py-2 text-md md:text-lg">Hier geht´s zum Kennnenlern-Call</Button>
      </a>

      <p class="italic text-sm mt-2 text-center md:text-start">Dein direkter Draht zu mir</p>
    </div>
  </div>
</section>
