---
import Button from "./ui/button.astro";
import { Image } from "astro:assets";
import LogoImage from "@assets/logo.webp";
---

<footer class="border-border/40 relative border-t bg-white px-6 py-16">
  <div class="mx-auto max-w-7xl">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-4 md:gap-8 lg:gap-12 items-start">
      {/* Left Column: Brand */}
      <Image
        alt="Logo"
        title="Logo"
        class="mx-auto h-auto w-[75%] rounded-[3rem] md:w-[45%]"
        src={LogoImage}
        loading="lazy"
        fetchpriority="low"
      />

      {/* Center Column: Links by Category */}
      <div class="flex flex-col justify-center space-y-4">
        <div class="space-y-2">
          <p class="font-heading text-foreground font-bold">Seiten</p>
          <div class="flex flex-col">
            <a
              href="/"
              title="Start"
              class="flex gap-2 items-center text-muted-foreground hover:text-primary w-fit transition-colors"
            >
              Start
            </a>
            <a
              href="/angebote"
              title="Angebote"
              class="flex gap-2 items-center text-muted-foreground hover:text-primary w-fit transition-colors"
            >
              Angebote
            </a>
            <a
              href="/ueber-mich"
              title="Über mich"
              class="flex gap-2 items-center text-muted-foreground hover:text-primary w-fit transition-colors"
            >
              Über mich
            </a>
          </div>
        </div>
      </div>

      {/* Center Column: Links by Category */}
      <div class="flex flex-col justify-center space-y-4">
        <div class="space-y-2">
          <p class="font-heading text-foreground font-bold">Rechtliches</p>
          <div class="flex flex-col">
            <a
              href="/impressum"
              title="Impressum"
              class="flex gap-2 items-center text-muted-foreground hover:text-primary w-fit transition-colors"
            >
              <i class="ph ph-user"></i>Impressum</a
            >
            <a
              href="/datenschutz"
              title="Datenschutz"
              class="flex gap-2 items-center text-muted-foreground hover:text-primary w-fit transition-colors"
            >
              <i class="ph ph-cookie"></i> Datenschutz</a
            >
          </div>
        </div>
      </div>

      {/* Right Column: CTA */}
      <div class="flex flex-col justify-center space-y-4">
        <div class="space-y-2">
          <p class="font-heading text-foreground font-bold">Kontakt</p>
          <div class="flex flex-col">
            <a
              href="mailto:sina@buchstabenfeder.de"
              class="flex gap-2 items-center text-muted-foreground hover:text-primary w-fit transition-colors"
              ><i class="ph ph-envelope"></i> sina@buchstabenfeder.de</a
            >
            <a
              href="https://www.instagram.com/buchstabenfeder/"
              title="Instagram von Buchstabenfeder"
              target="_blank"
              class="flex gap-2 items-center text-muted-foreground hover:text-primary w-fit transition-colors"
              ><i class="ph ph-instagram-logo"></i> Instagram <i class="ph ph-arrow-square-out"></i></a
            >
          </div>
        </div>

        <div class="w-full">
          <Button href="/kontakt" title="Termin buchen">Termin buchen</Button>
        </div>
      </div>
    </div>

    {/* Divider */}
    <div class="border-border/40 my-8 border-t"></div>

    {/* Bottom: Copyright */}
    <div
      class="text-muted-foreground/60 flex flex-col items-center justify-between gap-4 text-center text-sm md:flex-row"
    >
      <p>
        &copy; {new Date().getFullYear()} Buchstabenfeder - Alle Rechte vorbehalten.
      </p>
      <p class="flex items-center justify-center gap-1">
        Entwickelt von <a href="https://fredericbahr.github.io/" title="Frederic Bahrs Webseite">Frederic Bahr</a> mit <i
          class="ph ph-binary"></i>
      </p>
    </div>
  </div>
</footer>
