---
import { cn } from "@/lib/utils";

interface QuestionAnswerProps {
  id: string;
  question: string;
  class?: string;
}

const { id, question, class: className } = Astro.props as QuestionAnswerProps;
---

<details
  class={cn(
    "group bg-white overflow-hidden rounded-xl border border-gray-300 shadow-lg transition-all duration-300 hover:border-primary hover:shadow-xl",
    className,
  )}
  data-faq-id={id}
>
  <summary class="flex cursor-pointer list-none items-center justify-between p-6 transition-colors hover:bg-card/80">
    <h3 class="text-foreground text-lg font-sans pr-4">{question}</h3>
    <div class="text-accent transition-transform duration-300 group-open:rotate-180">
      <i class="ph ph-caret-down text-xl"></i>
    </div>
  </summary>

  <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out group-open:grid-rows-[1fr]">
    <div class="overflow-hidden border-t border-border/40 p-6">
      <slot />
    </div>
  </div>
</details>
