---
import { cn } from "@/lib/utils";

// TimelineStepper.astro

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class={cn("relative", className)}>
  <!-- Vertical line -->
  <div class="absolute left-2 top-0 bottom-0 w-px bg-gray-400 md:left-1/2 md:-translate-x-1/2"></div>

  <div class="space-y-12">
    <slot />
  </div>
</div>
