---
import { cn } from "@lib/utils";

interface ButtonProps {
  class?: string;
}

const { class: className } = Astro.props as ButtonProps;
---

<div
  class={cn(
    "group bg-white rounded-3xl max-w-sm p-8 border border-accent/30 hover:border-accent/50 transition-all duration-300 hover:shadow-lg",
    className,
  )}
>
  <slot />
</div>
