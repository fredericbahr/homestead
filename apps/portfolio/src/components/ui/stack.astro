---
import { cn } from "@lib/utils";
type Props = {
  spacing?: 0 | 1 | 2 | 3 | 4 | 6 | 8 | 12 | 18 | 24;
  align?: "start" | "center" | "end" | "stretch";
  justify?: "start" | "center" | "end" | "between" | "around";
  wrap?: boolean;
  class?: string;
  as?: keyof HTMLElementTagNameMap;
};

const {
  spacing = "2", // Tailwind spacing scale, e.g., 1-12
  align = "start", // start, center, end, stretch
  justify = "start", // start, center, end, between, around
  wrap = false, // only relevant for horizontal stacks
  as = "div",
  class: className = "",
} = Astro.props as Props;

const wrapClass = wrap ? "flex-wrap" : "";
const alignMap: Record<typeof align, string> = {
  start: "items-start",
  center: "items-center",
  end: "items-end",
  stretch: "items-stretch",
};
const justifyMap: Record<typeof justify, string> = {
  start: "justify-start",
  center: "justify-center",
  end: "justify-end",
  between: "justify-between",
  around: "justify-around",
};

const gapMap = {
  0: "gap-0",
  1: "gap-1",
  2: "gap-2",
  3: "gap-3",
  4: "gap-4",
  6: "gap-6",
  8: "gap-8",
  12: "gap-12",
  18: "gap-18",
  24: "gap-24",
};

const Tag = as;
---

<Tag
  class={cn(
    `flex flex-col ${wrapClass} ${alignMap[align]} ${justifyMap[justify]} ${gapMap[spacing]} ${className}`,
  )}
>
  <slot />
</Tag>
